# Copie para .env e ajuste conforme necessario.
# Credenciais alinhadas com o docker-compose.yml (Oracle Free 23ai).

ORACLE_USER=app
ORACLE_PASSWORD=app_pw
# host:porta/servico  -> FREEPDB1 e o PDB padrao do container gvenzl/oracle-free
ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1

# Porta da API
PORT=3000

# Auth JWT (troque o segredo em producao)
JWT_SECRET=dev-secret-troque-em-producao
JWT_EXPIRES_IN=8h

# Politica para campos extras nao cadastrados nos metadados:
#   passthrough -> aceita e grava no ATTRS (default da POC)
#   reject      -> rejeita com 422
UNKNOWN_FIELDS_POLICY=passthrough
